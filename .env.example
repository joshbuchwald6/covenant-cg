# Get a key at https://resend.com/api-keys
RESEND_API_KEY=re_your_key_here

# Where inquiry emails are delivered.
# IMPORTANT: Until covenant-cg.com is verified in Resend (Domains), you can only
# send from onboarding@resend.dev TO the same email you use to log into Resend.
# For testing: set CONTACT_TO_EMAIL to your Resend account email.
# For production: verify covenant-cg.com, then use e.g.:
#   CONTACT_FROM=Covenant <inquiries@covenant-cg.com>
#   CONTACT_TO_EMAIL=devin@covenant-cg.com
CONTACT_TO_EMAIL=devin@covenant-cg.com

# Sender. After domain verification, use an address @ your verified domain.
CONTACT_FROM=Covenant Website <onboarding@resend.dev>
